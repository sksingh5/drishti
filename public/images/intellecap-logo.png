<script>
document.addEventListener('wpcf7mailsent', function(event) {
 
    // Target only this specific form (optional but recommended)
    if (event.detail.contactFormId == 16163) {
 
        var formWrapper = document.querySelector('.genderform');
 
        if (formWrapper) {
 
            // Create download button
            var downloadDiv = document.createElement('div');
            downloadDiv.style.marginTop = "20px";
            downloadDiv.innerHTML = `
                <div style="text-align:center;">
                    <p style="font-size:16px;font-weight:500;color: #0a960a;">
                        Thank you! Your request has been received successfully.
                    </p>
 
                    <a href="https://genderinclusivity.org/" target="_blank"
                       style="display:inline-block;
                              margin-top:15px;margin-bottom:35px;
                              padding:12px 25px;
                              background:#0d6efd;
                              color:#ffffff;
                              text-decoration:none;
                              border-radius:5px;
                              font-weight:500;">
                        View the Gender Inclusivity Tool
                    </a>
                </div>
            `;
 
            formWrapper.appendChild(downloadDiv);
        }
    }
 
}, false);
</script>
