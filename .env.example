# Environment Variables
# Copy this file to .env.local and fill in actual values
# Never commit .env.local to version control

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (direct connection for pipeline)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Google Earth Engine (for NDVI vegetation data)
GEE_PROJECT=your-gcloud-project-id

# Copernicus CDS (for soil moisture data)
CDS_URL=https://cds.climate.copernicus.eu/api
CDS_KEY=your-cds-api-key
